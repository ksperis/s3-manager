{
  "general": {
    "manager_enabled": true,
    "browser_enabled": true,
    "portal_enabled": true,
    "allow_login_access_keys": true,
    "allow_login_endpoint_list": false,
    "allow_login_custom_endpoint": false
  },
  "portal": {
    "allow_portal_key": true,
    "allow_portal_user_bucket_create": true,
    "iam_group_manager_policy": {
      "actions": [
        "iam:*",
        "s3:*"
      ],
      "advanced_policy": null
    },
    "iam_group_user_policy": {
      "actions": [
        "s3:ListAllMyBuckets"
      ],
      "advanced_policy": null
    },
    "bucket_access_policy": {
      "actions": [
        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:ListBucketVersions",
        "s3:ListBucketMultipartUploads",
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:GetObjectTagging",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts",
        "s3:GetBucketVersioning",
        "s3:GetBucketCORS",
        "s3:GetBucketAcl",
        "s3:GetBucketPolicy",
        "s3:GetLifecycleConfiguration"
      ],
      "advanced_policy": null
    },
    "bucket_defaults": {
      "versioning": true,
      "enable_cors": true,
      "enable_lifecycle": true,
      "cors_allowed_origins": [
        "http://localhost:5173"
      ]
    }
  },
  "manager": {
    "allow_manager_user_usage_stats": true
  },
  "browser": {
    "allow_proxy_transfers": true,
    "direct_upload_parallelism": 5,
    "proxy_upload_parallelism": 2,
    "direct_download_parallelism": 5,
    "proxy_download_parallelism": 2,
    "other_operations_parallelism": 3
  }
}