# Application
# APP_NAME=s3-manager
# API_V1_PREFIX=/api

# Database
# DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql+psycopg://s3manager:s3manager@localhost:5432/s3manager

# CORS (JSON list)
# CORS_ORIGINS=["http://127.0.0.1:8080", "http://localhost:8080"]

# Auth / JWT
# FERNET_KEY=change-me
# JWT_KEYS=["change-me"]
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_MINUTES=20160
# REFRESH_TOKEN_COOKIE_NAME=refresh_token
# REFRESH_TOKEN_COOKIE_PATH=/api/auth
# REFRESH_TOKEN_COOKIE_DOMAIN=
# REFRESH_TOKEN_COOKIE_SECURE=false
# REFRESH_TOKEN_COOKIE_SAMESITE=lax

# App settings (optional)
# Path to app_settings.json (defaults to backend/app/data/app_settings.json)
# APP_SETTINGS_PATH=
#
# Feature kill-switch overrides (optional, force value when set)
# FEATURE_MANAGER_ENABLED=true
# FEATURE_BROWSER_ENABLED=true
# FEATURE_PORTAL_ENABLED=false
# FEATURE_CEPH_ADMIN_ENABLED=false
# FEATURE_BILLING_ENABLED=false
# FEATURE_ENDPOINT_STATUS_ENABLED=false
#
# Shared secret for internal cron endpoints
# INTERNAL_CRON_TOKEN=change-me-strong

# Credentials encryption at rest
# CREDENTIAL_KEY=change-me
# CREDENTIAL_KEYS=["change-me"]

# Env-managed endpoints (JSON array, read-only in UI)
# When set, the endpoints list becomes read-only in the UI.
# ENV_STORAGE_ENDPOINTS='[{"name":"Ceph-Prod","endpoint_url":"https://rgw.example.com","provider":"CEPH","region":"us-east-1","features":{"admin":{"enabled":true},"usage":{"enabled":true},"metrics":{"enabled":true}},"admin_access_key":"AKIA...","admin_secret_key":"SECRET...","supervision_access_key":"AKIA...","supervision_secret_key":"SECRET...","ceph_admin_access_key":"AKIA...","ceph_admin_secret_key":"SECRET..."}]'

# S3 / RGW seed connection
# SEED_S3_ENDPOINT=http://localhost:9000
# SEED_S3_ACCESS_KEY=minio
# SEED_S3_SECRET_KEY=minio123
# SEED_S3_REGION=us-east-1

# Default endpoint features (YAML or JSON)
# Example:
# SEED_S3_ENDPOINT_FEATURES='{"features":{"admin":{"enabled":true},"sts":{"enabled":true},"usage":{"enabled":true},"metrics":{"enabled":false},"static_website":{"enabled":true}}}'

# RGW admin ops (defaults to seed S3 values when empty)
# SEED_RGW_ADMIN_ACCESS_KEY=
# SEED_RGW_ADMIN_SECRET_KEY=

# Supervision access keys (usage stats)
# SEED_SUPERVISION_ACCESS_KEY=
# SEED_SUPERVISION_SECRET_KEY=

# Ceph Admin dedicated access keys (advanced cluster-wide ceph-admin workspace)
# SEED_CEPH_ADMIN_ACCESS_KEY=
# SEED_CEPH_ADMIN_SECRET_KEY=

# Default super-admin seed
# SEED_SUPER_ADMIN_EMAIL=admin@example.com
# SEED_SUPER_ADMIN_PASSWORD=changeme
# SEED_SUPER_ADMIN_FULL_NAME=Admin

# OIDC
# OIDC_STATE_TTL_SECONDS=600
# Example provider:
# OIDC_PROVIDERS__default__DISPLAY_NAME=Example
# OIDC_PROVIDERS__default__DISCOVERY_URL=https://issuer/.well-known/openid-configuration
# OIDC_PROVIDERS__default__CLIENT_ID=client-id
# OIDC_PROVIDERS__default__CLIENT_SECRET=client-secret
# OIDC_PROVIDERS__default__REDIRECT_URI=http://localhost:5173/auth/oidc/callback
# OIDC_PROVIDERS__default__SCOPES=openid,email,profile
# OIDC_PROVIDERS__default__PROMPT=login
# OIDC_PROVIDERS__default__ENABLED=true
# OIDC_PROVIDERS__default__ICON_URL=
# OIDC_PROVIDERS__default__USE_PKCE=true
# OIDC_PROVIDERS__default__USE_NONCE=true

# Healthchecks (endpoint supervision)
# HEALTHCHECK_ENABLED=true
# HEALTHCHECK_TIMEOUT_SECONDS=5
# HEALTHCHECK_INTERVAL_SECONDS=300
# HEALTHCHECK_RETENTION_DAYS=30
# HEALTHCHECK_DEGRADED_LATENCY_MS=2000
# HEALTHCHECK_VERIFY_SSL=true
# HEALTHCHECK_LATENCY_BASELINE_WINDOW_DAYS=7
# HEALTHCHECK_BASELINE_SAMPLE_SIZE=80
# HEALTHCHECK_RELATIVE_DEGRADED_RATIO=1.8
# HEALTHCHECK_RELATIVE_DEGRADED_MIN_DELTA_MS=200
# HEALTHCHECK_INCIDENT_RECENT_MINUTES=720

# Bucket migrations
# BUCKET_MIGRATION_WORKER_ENABLED=true
# BUCKET_MIGRATION_POLL_INTERVAL_SECONDS=2.0
# BUCKET_MIGRATION_PARALLELISM_MAX=16
# BUCKET_MIGRATION_MAX_ACTIVE_PER_ENDPOINT=2
# BUCKET_MIGRATION_WORKER_LEASE_SECONDS=120
