# Application
APP_NAME=s3-manager
API_V1_PREFIX=/api
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:///./app.db

# S3 / RGW
S3_ENDPOINT=http://localhost:9000
# Default endpoint features (YAML or JSON)
# Example:
# S3_ENDPOINT_FEATURES='{"features":{"admin":{"enabled":true},"sts":{"enabled":true},"usage":{"enabled":true},"metrics":{"enabled":false},"static_website":{"enabled":true}}}'
S3_ENDPOINT_FEATURES=
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_REGION=us-east-1

# RGW admin ops (defaults to S3 values when empty)
RGW_ADMIN_ACCESS_KEY=
RGW_ADMIN_SECRET_KEY=
SUPERVISION_ACCESS_KEY=
SUPERVISION_SECRET_KEY=

# Default super-admin seed
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme
SUPER_ADMIN_FULL_NAME=Admin

# CORS (JSON list)
CORS_ORIGINS=["http://localhost:5173"]

# OIDC
OIDC_STATE_TTL_SECONDS=600
# Example provider:
# OIDC_PROVIDERS__default__DISPLAY_NAME=Example
# OIDC_PROVIDERS__default__DISCOVERY_URL=https://issuer/.well-known/openid-configuration
# OIDC_PROVIDERS__default__CLIENT_ID=client-id
# OIDC_PROVIDERS__default__CLIENT_SECRET=client-secret
# OIDC_PROVIDERS__default__REDIRECT_URI=http://localhost:5173/auth/oidc/callback
# OIDC_PROVIDERS__default__SCOPES=openid,email,profile
# OIDC_PROVIDERS__default__PROMPT=login
# OIDC_PROVIDERS__default__ENABLED=true
# OIDC_PROVIDERS__default__ICON_URL=
# OIDC_PROVIDERS__default__USE_PKCE=true
# OIDC_PROVIDERS__default__USE_NONCE=true
