{
  "name": "s3-manager-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint src/components src/features/auth/LoginPage.tsx src/features/auth/OidcCallbackPage.tsx src/features/manager/ManagerMigrationsPage.tsx src/router.tsx src/utils/routePrefetch.ts src/test --ext .ts,.tsx",
    "lint:browser": "eslint src/features/browser/BrowserPage.tsx src/features/browser/ObjectAdvancedModal.tsx src/features/browser/BrowserDialogModals.tsx --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run --testNamePattern=a11y",
    "budget:check": "node ./scripts/check-bundle-budget.mjs",
    "chunks:check": "node ./scripts/check-chunk-cycles.mjs",
    "check": "npm run lint && npm run lint:browser && npm run typecheck && npm run test && npm run build && npm run chunks:check && npm run budget:check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@zip.js/zip.js": "^2.7.57",
    "axios": "^1.6.7",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.4.0",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.36.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4",
    "vite": "^5.0.10"
  }
}
